{
  "name": "blossom-schoolcatering",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@9.15.4",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @blossom/web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @blossom/web build",
    "build:api": "pnpm --filter api build",
    "preview": "pnpm --filter @blossom/web start",
    "test": "npm run test:unit",
    "test:unit": "./scripts/qa/run_unit_tests.sh",
    "test:integration": "./scripts/qa/run_integration_tests.sh",
    "test:e2e": "./scripts/qa/run_e2e_role_tests.sh",
    "test:regression": "./scripts/qa/run_regression_suite.sh",
    "test:security": "./scripts/qa/run_security_tests.sh",
    "test:performance": "./scripts/qa/run_performance_tests.sh",
    "test:qa": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:regression && npm run test:security && npm run test:performance",
    "build:types": "pnpm --filter @blossom/types build",
    "check:config": "pnpm --filter @blossom/config validate"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com-net1io:Gaia-Digital-Agency/blossom_schoolcatering.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
